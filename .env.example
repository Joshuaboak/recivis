# ReCivis environment variables — placeholder values only.
# Copy to .env.local and fill in real values before `npm run dev`.
# Never commit .env.local. Secrets belong in Railway for production.

# --- Required ---

# PostgreSQL connection string. For local dev against Railway Postgres,
# use the PUBLIC hostname (not the Railway-internal one, which only
# resolves inside the Railway network).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Zoho MCP endpoint. Embeds an API key that rotates periodically —
# pull the current value from the operator's password store.
ZOHO_MCP_URL=https://mcp.zoho.com.au/...

# Zoho REST API key (zapikey) for Deluge function calls (lead
# conversion, renewal generation, coupon writes, password resets).
ZOHO_API_KEY=replace-me

# JWT signing secret. getJwtSecret() fails loudly in production if
# this is unset — dev falls back to a placeholder.
JWT_SECRET=change-me-locally-and-set-a-real-one-in-prod

# OpenRouter API key for AI chat + file-parsing endpoints.
OPENROUTER_API_KEY=sk-or-...

# Google service-account JSON for Gmail send flow. Either the raw
# JSON string or a base64-encoded copy of it.
GOOGLE_SERVICE_ACCOUNT_KEY=

# Primary "From:" address for Gmail send operations.
GMAIL_SENDER=noreply@example.com.au

# Audit BCC address — every outbound email is BCC'd here.
GMAIL_BCC=audit@example.com.au

# Public base URL used when generating email links (password reset
# etc.). In production this is the Railway deploy URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Optional ---

# Redis cache. App starts cleanly without this — the cache layer
# returns nulls if Redis is unreachable.
REDIS_URL=

# NODE_ENV toggles SSL-reject-unauthorized on the pg pool and other
# prod-only safeguards. Next.js sets this automatically for build /
# start; leave unset locally.
# NODE_ENV=development
